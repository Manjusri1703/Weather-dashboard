pipeline {
    agent any

    tools {
        nodejs 'NodeJS'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
            }
        }

        stage('Lint') {
            steps {
                bat 'npm run lint'
            }
        }

        stage('Build') {
            steps {
                bat 'npm run build'
            }
        }

        stage('Archive Artifacts') {
            steps {
                archiveArtifacts artifacts: '.next/**', fingerprint: true
            }
        }
    }

    post {

    always {
        echo 'Pipeline Finished'
    }

    success {
        echo 'Build Successful'

        slackSend(
            channel: '#jenkins',
            color: 'good',
            message: "✅ ${env.JOB_NAME} Build #${env.BUILD_NUMBER} Successful"
        )
    }

    failure {
        echo 'Build Failed'

        slackSend(
            channel: '#jenkins',
            color: 'danger',
            message: "❌ ${env.JOB_NAME} Build #${env.BUILD_NUMBER} Failed"
        )
    }
}
}